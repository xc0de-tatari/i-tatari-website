---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FloatingActions from '../components/FloatingActions.astro';
import StickyMobileCta from '../components/conversion/StickyMobileCta.astro';
import HomePage from '../components/home/HomePage.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { getPageSeoBundle } from '../lib/page-seo';
import { keywordFaqs } from '../data/keyword-faqs';
import { faqs as coreFaqs } from '../data/site';
import { buildFaqSchema, canonicalUrl } from '../lib/seo';

const homeSeo = getPageSeoBundle('/', {
  metaTitle: 'Tatari Investment | Ägypten, Dubai & Saudi-Arabien',
  metaDescription:
    'Immobilien in Ägypten, Dubai und Saudi-Arabien: Offplan, Premium-Projekte, deutschsprachige Vermittlung. West Wind Sheikh Zayed — vorbehaltlich Verfügbarkeit.',
});
const seen = new Set<string>();
const homeFaqs = [...coreFaqs, ...keywordFaqs].filter((faq) => {
  const key = faq.q.toLowerCase().trim();
  if (seen.has(key)) return false;
  seen.add(key);
  return true;
});
const faqSchema = buildFaqSchema(homeFaqs.slice(0, 12));
---

<Layout
  title={homeSeo.metaTitle}
  description={homeSeo.metaDescription}
  keywords={homeSeo.metaKeywords}
  canonical={canonicalUrl('/')}
>
  {faqSchema && (
    <Fragment slot="head">
      <JsonLd data={faqSchema} />
    </Fragment>
  )}
  <Header locale="de" />
  <main id="main-content">
    <HomePage locale="de" />
  </main>
  <Footer locale="de" />
  <FloatingActions />
  <StickyMobileCta />
</Layout>
