---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CTAButton from '../components/conversion/CTAButton.astro';
import WhatsAppButton from '../components/conversion/WhatsAppButton.astro';
import { canonicalUrl } from '../lib/seo';

const title = 'Danke für Ihre Anfrage | Tatari Investment';
const description = 'Ihre Investment-Anfrage ist eingegangen. Tatari meldet sich zeitnah.';
---

<Layout title={title} description={description} canonical={canonicalUrl('/danke')} noindex={true}>
  <Header />
  <main id="main-content">
    <section class="hero" style="min-height:60vh">
      <div class="container hero-content center">
        <p class="section-label" style="justify-content:center">✓ Erfolgreich</p>
        <h1>Danke — Ihre Anfrage ist angekommen</h1>
        <p class="hero-desc" style="max-width:560px;margin-inline:auto">
          Unser Team meldet sich zeitnah mit Verfügbarkeit, Grundrissen und Euro-Kalkulation —
          vorbehaltlich Prüfung und Verfügbarkeit.
        </p>
        <div class="hero-actions">
          <CTAButton href="/" label="Zur Startseite" variant="outline" />
          <WhatsAppButton template="germany" />
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
