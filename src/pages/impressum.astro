---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import LegalNav from '../components/legal/LegalNav.astro';
import { canonicalUrl } from '../lib/seo';
import { legalPaths, links } from '../data/links';

const title = 'Impressum | Hometrend & Tatari Investments';
const description =
  'Impressum und Anbieterkennzeichnung gemäß § 5 TMG — Hometrend & Tatari Investments, Ettlingen, Frankfurt und Kairo.';
const impressumPhone = '+49 171 4733388';
const impressumPhoneTel = '+491714733388';
---

<Layout
  title={title}
  description={description}
  canonical={canonicalUrl(legalPaths.impressum)}
  includeLocalBusiness={false}
>
  <Header />
  <main id="main-content">
    <article class="legal-page section">
      <div class="container legal-page-inner">
        <header class="legal-page-header">
          <p class="section-label">Rechtliches</p>
          <h1>Impressum</h1>
        </header>

        <LegalNav />

        <section class="legal-block" aria-labelledby="impressum-tmg">
          <h2 id="impressum-tmg">Angaben gemäß § 5 TMG</h2>
          <h3>Hometrend &amp; Tatari Investments</h3>
          <p><strong>Geschäftsführer:</strong></p>
          <ul class="legal-list">
            <li>Frank Deubrecht</li>
            <li>Taleb Tatari</li>
          </ul>
        </section>

        <section class="legal-block" aria-labelledby="impressum-de">
          <h2 id="impressum-de">Deutschland – Hauptsitz</h2>
          <address class="legal-address">
            <strong>Hometrend</strong><br />
            Hydenstraße 17<br />
            76275 Ettlingen<br />
            Deutschland
          </address>
        </section>

        <section class="legal-block" aria-labelledby="impressum-frankfurt">
          <h2 id="impressum-frankfurt">Repräsentanz Frankfurt</h2>
          <address class="legal-address">
            Bockenheimer Landstraße 2–4<br />
            60306 Frankfurt am Main<br />
            Deutschland
          </address>
        </section>

        <section class="legal-block" aria-labelledby="impressum-me">
          <h2 id="impressum-me">Middle East Office</h2>
          <address class="legal-address">
            <strong>Tatari Investments</strong><br />
            Arkan Plaza – Building 4<br />
            Sheikh Zayed<br />
            Kairo<br />
            Ägypten
          </address>
        </section>

        <section class="legal-block" aria-labelledby="impressum-kontakt">
          <h2 id="impressum-kontakt">Kontakt</h2>
          <dl class="legal-dl">
            <dt>Telefon</dt>
            <dd><a href={`tel:${impressumPhoneTel}`}>{impressumPhone}</a></dd>
            <dt>E-Mail</dt>
            <dd><a href={`mailto:${links.email}`}>{links.email}</a></dd>
            <dt>Website</dt>
            <dd><a href="https://www.i-tatari.com">https://www.i-tatari.com</a></dd>
          </dl>
        </section>

        <section class="legal-block" aria-labelledby="impressum-rstv">
          <h2 id="impressum-rstv">Verantwortlich für den Inhalt nach § 55 Abs. 2 RStV</h2>
          <ul class="legal-list">
            <li>Frank Deubrecht</li>
            <li>Taleb Tatari</li>
          </ul>
        </section>

        <section class="legal-block" aria-labelledby="impressum-haftung">
          <h2 id="impressum-haftung">Haftungsausschluss</h2>
          <p>
            Die Inhalte dieser Website wurden mit größtmöglicher Sorgfalt erstellt. Dennoch übernehmen wir keine
            Gewähr für die Vollständigkeit, Richtigkeit oder Aktualität der bereitgestellten Inhalte.
          </p>
          <p>
            Alle Informationen auf dieser Website dienen ausschließlich allgemeinen Informationszwecken und stellen keine
            rechtliche, steuerliche oder finanzielle Beratung dar.
          </p>
          <p>
            Immobilieninvestitionen sind mit Risiken verbunden. Renditen, Wertsteigerungen und Mieteinnahmen sind nicht
            garantiert. Preise, Wechselkurse, Verfügbarkeiten und Zahlungspläne können sich jederzeit ändern.
          </p>
        </section>

        <section class="legal-block" aria-labelledby="impressum-urheber">
          <h2 id="impressum-urheber">Urheberrecht</h2>
          <p>
            Die auf dieser Website veröffentlichten Inhalte, Bilder, Designs, Texte und Medien unterliegen dem
            Urheberrecht und dürfen ohne ausdrückliche schriftliche Genehmigung nicht vervielfältigt, bearbeitet oder
            verbreitet werden.
          </p>
        </section>

        <section class="legal-block" aria-labelledby="impressum-odr">
          <h2 id="impressum-odr">Online-Streitbeilegung gemäß Art. 14 Abs. 1 ODR-VO</h2>
          <p>
            Die Europäische Kommission stellt eine Plattform zur Online-Streitbeilegung (OS) bereit:
          </p>
          <p>
            <a href="https://ec.europa.eu/consumers/odr/" target="_blank" rel="noopener noreferrer">
              https://ec.europa.eu/consumers/odr/
            </a>
          </p>
          <p>
            Wir sind nicht verpflichtet und nicht bereit, an Streitbeilegungsverfahren vor einer
            Verbraucherschlichtungsstelle teilzunehmen.
          </p>
        </section>

        <p class="legal-back">
          <a href="/" class="btn btn-outline">← Zur Startseite</a>
          <a href={legalPaths.datenschutz} class="btn btn-outline">Datenschutz</a>
          <a href={legalPaths.agb} class="btn btn-outline">AGB</a>
        </p>
      </div>
    </article>
  </main>
  <Footer />
</Layout>
