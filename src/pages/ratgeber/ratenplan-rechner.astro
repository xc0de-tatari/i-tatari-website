---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FloatingActions from '../../components/FloatingActions.astro';
import InstallmentCalculator from '../../components/conversion/InstallmentCalculator.astro';
import LeadForm from '../../components/conversion/LeadForm.astro';
import { leadMagnets } from '../../data/lead-magnets';
import { canonicalUrl } from '../../lib/seo';

const magnet = leadMagnets.find((m) => m.id === 'ratenplan-rechner')!;
---

<Layout
  title={`${magnet.title} | Tatari Investment`}
  description={magnet.description}
  canonical={canonicalUrl('/ratgeber/ratenplan-rechner')}
>
  <Header />
  <main id="main-content">
    <section class="section">
      <div class="container">
        <h1 class="section-title">{magnet.title}</h1>
        <p class="section-desc">{magnet.description}</p>
        <InstallmentCalculator />
        <div style="margin-top:2rem">
          <LeadForm title="Individuelle Ratenplan-Prüfung" source="magnet-ratenplan" magnetId="ratenplan-rechner" />
        </div>
      </div>
    </section>
  </main>
  <Footer />
  <FloatingActions />
</Layout>
