---
import type { Locale } from '../i18n';
import { getSiteContent, getPageSections, getUi } from '../i18n/content';

interface Props {
  locale?: Locale;
}

const locale = Astro.props.locale ?? 'de';
const { newsItems } = getSiteContent(locale);
const t = getUi(locale).news;
const sections = getPageSections(locale);
---

<section class="section section-alt">
  <div class="container center">
    <p class="section-label" style="justify-content:center">{t.label}</p>
    <h2 class="section-title">{t.title}</h2>
    <p class="section-desc">
      {locale === 'en'
        ? 'Latest developments across Egypt, Dubai and Saudi Arabia'
        : 'Die heißesten Entwicklungen und warum JETZT der perfekte Zeitpunkt ist'}
    </p>
  </div>

  <div class="container news-grid">
    {newsItems.map((item) => (
      <article class="news-card">
        <div class="news-meta">
          <span class="badge badge-urgent">{item.badge}</span>
          {item.year && <span class="news-year">{item.year}</span>}
        </div>
        <h3>{item.title}</h3>
        <p>{item.desc}</p>
        <p class="news-impact">
          <strong>{locale === 'en' ? 'Impact:' : 'Impact:'}</strong> {item.impact}
        </p>
      </article>
    ))}
  </div>

  <div class="container center" style="margin-top:2rem">
    <a href={sections.kontakt} class="btn btn-primary">
      {locale === 'en' ? 'Discuss market timing' : 'Markt-Timing besprechen'}
    </a>
  </div>
</section>
