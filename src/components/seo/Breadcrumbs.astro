---
interface Crumb {
  name: string;
  url: string;
}

interface Props {
  items: Crumb[];
}

const { items } = Astro.props;
---

<nav class="breadcrumb" aria-label="Brotkrumen">
  {items.map((item, i) => (
    <>
      {i > 0 && <span aria-hidden="true">/</span>}
      {i === items.length - 1 ? (
        <span aria-current="page">{item.name}</span>
      ) : (
        <a href={item.url}>{item.name}</a>
      )}
    </>
  ))}
</nav>

<style>
  .breadcrumb {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 0.5rem;
    justify-content: center;
    font-size: 0.8rem;
    color: var(--text-dim);
    margin-bottom: 1.5rem;
  }

  .breadcrumb a:hover {
    color: var(--gold);
  }
</style>
