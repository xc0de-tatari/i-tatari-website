---
import { imageSrcSet } from '../../lib/images';

interface Props {
  src: string;
  alt: string;
  width: number;
  height: number;
  /** LCP / hero images */
  priority?: boolean;
  sizes?: string;
  class?: string;
}

const {
  src,
  alt,
  width,
  height,
  priority = false,
  sizes = '(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 33vw',
  class: className,
} = Astro.props;

const srcset = imageSrcSet(src);
---

<img
  src={src}
  srcset={srcset || undefined}
  sizes={srcset ? sizes : undefined}
  alt={alt}
  width={width}
  height={height}
  class={className}
  loading={priority ? 'eager' : 'lazy'}
  decoding="async"
  fetchpriority={priority ? 'high' : 'auto'}
/>
