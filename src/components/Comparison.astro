---
import type { Locale } from '../i18n';
import { getSiteContent, getPageSections, getUi } from '../i18n/content';
interface Props {
  locale?: Locale;
}

const locale = Astro.props.locale ?? 'de';
const { comparisonRows } = getSiteContent(locale);
const t = getUi(locale).comparison;
const sections = getPageSections(locale);
---

<section class="section">
  <div class="container center">
    <p class="section-label" style="justify-content:center">{t.label}</p>
    <h2 class="section-title">{t.title}</h2>
    <p class="section-desc">{t.desc}</p>
  </div>

  <div class="container comparison-wrap">
    <table class="comparison-table">
      <thead>
        <tr>
          <th>{locale === 'en' ? 'Category' : 'Kategorie'}</th>
          <th>🇦🇪 {t.dubai}</th>
          <th>🇪🇬 {t.egypt}</th>
          <th>🇩🇪 {t.germany}</th>
        </tr>
      </thead>
      <tbody>
        {comparisonRows.map((row) => (
          <tr>
            <td>{row.category}</td>
            <td class="col-dubai">{row.dubai}</td>
            <td class="col-egypt">{row.egypt}</td>
            <td class="col-de">{row.germany}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <div class="container comparison-benefits">
    <div class="comparison-benefit"><h4>Renditepotenzial</h4><p>Szenarien — nicht garantiert</p></div>
    <div class="comparison-benefit"><h4>Steuerliche Prüfung</h4><p>Individuell klären</p></div>
    <div class="comparison-benefit"><h4>Strukturierter Prozess</h4><p>Due Diligence & DE-Beratung</p></div>
    <div class="comparison-benefit"><h4>West Wind</h4><p>Sheikh Zayed Mixed-Use</p></div>
  </div>

  <div class="container comparison-cta">
    <h3>{t.ctaTitle}</h3>
    <p style="color:var(--text-muted);margin:1rem 0 1.5rem">{t.ctaDesc}</p>
    <a href={sections.kontakt} class="btn btn-primary">{t.ctaBtn}</a>
  </div>
</section>
