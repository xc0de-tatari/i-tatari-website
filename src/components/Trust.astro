---
import { steps } from '../data/site';
import { images } from '../data/images';

const miniTestimonials = [
  { quote: 'Anfangs war ich skeptisch, aber Tatari hat mich durch jeden Schritt begleitet. Meine Investition in Dubai läuft perfekt!', name: 'Michael K.', city: 'München' },
  { quote: 'Die Transparenz und Professionalität haben mich überzeugt. Ich besitze jetzt eine Wohnung in New Cairo mit nur 4.000€ Anzahlung.', name: 'Sarah W.', city: 'Hamburg' },
  { quote: 'Als deutscher Makler weiß Tatari genau, worauf es ankommt. Ich plane bereits mein zweites Investment.', name: 'Thomas B.', city: 'Frankfurt' },
];

const concerns = [
  { title: 'Angst vor Betrug', desc: 'Wir sind registrierte deutsche Makler mit nachweisbarer Erfolgsbilanz' },
  { title: 'Sprachbarrieren', desc: 'Komplette Betreuung auf Deutsch von Anfang bis Ende' },
  { title: 'Rechtliche Unsicherheit', desc: 'Alle Verträge werden von Fachanwälten geprüft' },
  { title: 'Zu hohes Risiko', desc: 'Nur geprüfte Projekte renommierter Entwickler' },
];
---

<section class="section section-alt">
  <div class="container center">
    <p class="section-label" style="justify-content:center">Vertrauen & Sicherheit</p>
    <h2 class="section-title">Deutsche Expertise, maximale Sicherheit</h2>
    <p class="section-desc">Wir verstehen Ihre Bedenken. Deshalb setzen wir auf 100% Transparenz und persönliche Betreuung.</p>
  </div>

  <div class="container benefits-grid" style="margin-top:2rem">
    <article class="benefit-card">
      <div class="benefit-icon">⚖️</div>
      <h3>Rechtssicherheit</h3>
      <p>Alle Verträge werden von deutschen Anwälten geprüft und entsprechen internationalen Standards.</p>
    </article>
    <article class="benefit-card">
      <div class="benefit-icon">📅</div>
      <h3>10+ Jahre Erfahrung</h3>
      <p>Hunderte erfolgreiche Transaktionen in Offland-Immobilien mit nachweisbarer Erfolgsbilanz.</p>
    </article>
    <article class="benefit-card">
      <div class="benefit-icon">🇩🇪</div>
      <h3>Deutschsprachig</h3>
      <p>Ihr persönlicher Berater spricht Deutsch und ist jederzeit für Sie erreichbar.</p>
    </article>
  </div>

  <div class="container trust-visual" style="margin-top:3rem">
    <div class="trust-image-wrap">
      <img src={images.trustHandshake} alt="Vertrauen und Partnerschaft" loading="lazy" width="1080" height="720" />
    </div>
  </div>

  <div class="container" style="margin-top:3rem">
    <h3 class="section-title center" style="font-size:1.5rem">In 4 Schritten zur Immobilie</h3>
    <p class="center section-desc" style="margin-inline:auto">So einfach investieren Sie mit Tatari</p>
    <div class="steps-grid">
      {steps.map((s) => (
        <div class="step-card">
          <p class="step-num">{s.num}</p>
          <h4>{s.title}</h4>
          <p>{s.desc}</p>
        </div>
      ))}
    </div>
  </div>

  <div class="container" style="margin-top:3rem">
    <h3 class="section-title center" style="font-size:1.35rem">Das sagen unsere Kunden</h3>
    <p class="center" style="color:var(--text-muted);margin-bottom:1.5rem">Über 500 zufriedene Investoren vertrauen uns bereits</p>
    <div class="testimonials-grid">
      {miniTestimonials.map((t) => (
        <article class="testimonial-card">
          <p>"{t.quote}"</p>
          <strong>{t.name}</strong>
          <span style="display:block;font-size:0.8rem;color:var(--text-dim)">{t.city}</span>
        </article>
      ))}
    </div>
  </div>

  <div class="container" style="margin-top:3rem">
    <h3 class="section-title center" style="font-size:1.35rem">Warum zögern viele Investoren?</h3>
    <div class="concerns-grid">
      {concerns.map((c) => (
        <div class="concern-item">
          <h4>{c.title}</h4>
          <p>{c.desc}</p>
        </div>
      ))}
    </div>
    <p class="highlight-box" style="margin-top:2rem">
      Ihre Sicherheit ist unsere Priorität. Wir bieten nicht nur Immobilien, sondern vollständige Transparenz, Betreuung und Absicherung für deutsche Investoren.
    </p>
  </div>
</section>
