---
import type { Locale } from '../i18n';
import { getSiteContent, getUi } from '../i18n/content';
import { images } from '../data/images';

interface Props { locale?: Locale }
const locale = Astro.props.locale ?? 'de';
const { steps } = getSiteContent(locale);
const t = getUi(locale).trust;
---

<section class="section section-alt">
  <div class="container center">
    <p class="section-label" style="justify-content:center">{t.label}</p>
    <h2 class="section-title">{t.title}</h2>
    <p class="section-desc">{t.desc}</p>
  </div>

  <div class="container benefits-grid" style="margin-top:2rem">
    {t.benefits.map((b) => (
      <article class="benefit-card">
        <div class="benefit-icon">{b.icon}</div>
        <h3>{b.title}</h3>
        <p>{b.desc}</p>
      </article>
    ))}
  </div>

  <div class="container trust-visual" style="margin-top:3rem">
    <div class="trust-image-wrap">
      <img src={images.trustHandshake} alt={t.imgAlt} loading="lazy" width="1080" height="720" />
    </div>
  </div>

  <div class="container" style="margin-top:3rem">
    <h3 class="section-title center" style="font-size:1.5rem">{t.processTitle}</h3>
    <p class="center section-desc" style="margin-inline:auto">{t.processSub}</p>
    <div class="steps-grid">
      {steps.map((s) => (
        <div class="step-card">
          <p class="step-num">{s.num}</p>
          <h4>{s.title}</h4>
          <p>{s.desc}</p>
        </div>
      ))}
    </div>
  </div>

  <div class="container" style="margin-top:3rem">
    <h3 class="section-title center" style="font-size:1.35rem">{t.testimonialsTitle}</h3>
    <p class="center" style="color:var(--text-muted);margin-bottom:1.5rem">{t.testimonialsSub}</p>
    <div class="testimonials-grid">
      {t.mini.map((item) => (
        <article class="testimonial-card">
          <p>"{item.quote}"</p>
          <strong>{item.name}</strong>
          <span style="display:block;font-size:0.8rem;color:var(--text-dim)">{item.city}</span>
        </article>
      ))}
    </div>
  </div>

  <div class="container" style="margin-top:3rem">
    <h3 class="section-title center" style="font-size:1.35rem">{t.concernsTitle}</h3>
    <div class="concerns-grid">
      {t.concerns.map((c) => (
        <div class="concern-item">
          <h4>{c.title}</h4>
          <p>{c.desc}</p>
        </div>
      ))}
    </div>
    <p class="highlight-box" style="margin-top:2rem">{t.priorityBox}</p>
  </div>
</section>
