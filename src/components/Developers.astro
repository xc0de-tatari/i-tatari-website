---
import type { Locale } from '../i18n';
import { getSiteContent, getUi } from '../i18n/content';

interface Props {
  locale?: Locale;
}

const locale = Astro.props.locale ?? 'de';
const { developers, trustStats } = getSiteContent(locale);
const t = getUi(locale).developers;
const doubled = [...developers, ...developers];
---

<section class="developers">
  <div class="container">
    <p class="section-label center" style="justify-content:center">{t.label}</p>
    <h3>{t.title}</h3>
    <p class="sub">{t.desc}</p>
  </div>

  <div class="marquee">
    <div class="marquee-track">
      {doubled.map((dev) => (
        <div class="dev-card">
          <div class="dev-abbr">{dev.abbr}</div>
          <div class="dev-name">{dev.name}</div>
        </div>
      ))}
    </div>
  </div>

  <div class="container" style="margin-top: 3rem;">
    <div class="stats-grid">
      {trustStats.map((stat) => (
        <div class="stat-card">
          <div class="stat-value">{stat.value}</div>
          <div class="stat-label">{stat.label}</div>
        </div>
      ))}
    </div>

    <div class="trust-bar">
      <span>100% Deutsche Beratung</span>
      <span>Rechtlich Abgesichert</span>
      <span>Kostenlose Erstberatung</span>
      <span>Transparente Prozesse</span>
    </div>
  </div>
</section>
