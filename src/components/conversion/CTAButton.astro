---
interface Props {
  href: string;
  label: string;
  variant?: 'primary' | 'outline';
  external?: boolean;
  large?: boolean;
}

const { href, label, variant = 'primary', external = false, large = false } = Astro.props;
---

<a
  href={href}
  class:list={['btn', variant === 'primary' ? 'btn-primary' : 'btn-outline', large && 'btn-lg']}
  target={external ? '_blank' : undefined}
  rel={external ? 'noopener noreferrer' : undefined}
>
  {label}
</a>

<style>
  .btn-lg {
    padding: 1rem 2rem;
    font-size: 1.05rem;
  }
</style>
