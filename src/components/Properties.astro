---
import type { Locale } from '../i18n';
import { getSiteContent, getPageSections, getUi } from '../i18n/content';
import { propertyImages } from '../data/images';
import OptimizedImage from './seo/OptimizedImage.astro';
import { defaultSizes } from '../lib/images';
import { imageAlt } from '../lib/seo';

interface Props {
  locale?: Locale;
}

const locale = Astro.props.locale ?? 'de';
const { properties } = getSiteContent(locale);
const t = getUi(locale).properties;
const sections = getPageSections(locale);
const projectsHref = locale === 'en' ? '/en/projects' : '/projekte';
---

<section id={locale === 'en' ? 'properties' : 'objekte'} class="section">
  <div class="container center">
    <p class="section-label" style="justify-content:center">{t.sectionLabel}</p>
    <h2 class="section-title">{t.sectionTitle}</h2>
    <p class="section-desc">{t.sectionDesc}</p>
  </div>

  <div class="container properties-grid">
    {properties.map((p) => (
      <article class="property-card">
        <div class="property-image">
          <OptimizedImage
            src={propertyImages[p.title] ?? propertyImages['West Wind — Medical Unit']}
            alt={imageAlt(p.title, p.area, p.location)}
            width={400}
            height={250}
            sizes={defaultSizes('card')}
          />
          <div class="property-tags">
            {p.featured && <span class="badge badge-gold">{t.flagship}</span>}
            <span class="badge badge-gold">⏱️ {p.timeline}</span>
          </div>
        </div>
        <div class="property-body">
          <p class="property-location">{p.location}</p>
          <h3>{p.title}</h3>
          <p class="property-area">{p.area}</p>
          <div class="property-price-row">
            <div>
              <span>{t.total}</span>
              <strong>{p.price}</strong>
            </div>
            <div>
              <span>{t.down}</span>
              <strong>{p.down}</strong>
            </div>
          </div>
          <div class="property-specs">
            <div><span>{t.rooms}</span><strong>{p.rooms}</strong></div>
            <div><span>{t.baths}</span><strong>{p.baths}</strong></div>
            <div><span>{t.area}</span><strong>{p.sqm}m²</strong></div>
            <div><span>{t.potential}</span><strong style="color:var(--gold)">{p.yieldNote}</strong></div>
          </div>
          <div class="property-roi">
            <span>{t.rent}</span>
            <strong>{p.rent}</strong>
          </div>
          <div class="property-features">
            {p.features.map((f) => (
              <span>✓ {f}</span>
            ))}
          </div>
          <p class="property-developer">{t.developer}: {p.developer}</p>
          <a href={p.href ?? sections.kontakt} class="btn btn-primary">{t.cta}</a>
        </div>
      </article>
    ))}
  </div>

  <div class="container portfolio-cta">
    <h3>{t.portfolioTitle}</h3>
    <p style="color:var(--text-muted);margin:1rem 0 1.5rem">{t.portfolioDesc}</p>
    <a href={projectsHref} class="btn btn-outline" style="margin-right:0.75rem">{t.portfolioBtn}</a>
    <a href={sections.kontakt} class="btn btn-primary">{t.portfolioCta}</a>
  </div>
</section>
