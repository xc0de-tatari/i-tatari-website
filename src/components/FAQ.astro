---
import type { Locale } from '../i18n';
import { getSiteContent, getPageSections, getUi } from '../i18n/content';
import { keywordFaqs } from '../data/keyword-faqs';

interface Props {
  locale?: Locale;
}

const locale = Astro.props.locale ?? 'de';
const { faqs: coreFaqs } = getSiteContent(locale);
const t = getUi(locale).faq;
const sections = getPageSections(locale);

const seen = new Set<string>();
const allFaqs =
  locale === 'en'
    ? coreFaqs.slice(0, 12)
    : [...coreFaqs, ...keywordFaqs].filter((faq) => {
        const key = faq.q.toLowerCase().trim();
        if (seen.has(key)) return false;
        seen.add(key);
        return true;
      });
---

<section id="faq" class="section">
  <div class="container center">
    <p class="section-label" style="justify-content:center">{t.label}</p>
    <h2 class="section-title">{t.title}</h2>
    <p class="section-desc">{t.desc}</p>
  </div>

  <div class="container faq-list">
    {allFaqs.map((faq, i) => (
      <div class={`faq-item ${i === 0 ? 'open' : ''}`}>
        <button type="button" class="faq-question">{faq.q}</button>
        <div class="faq-answer">
          <p>{faq.a}</p>
        </div>
      </div>
    ))}
  </div>

  <div class="container comparison-cta" style="margin-top:2.5rem">
    <h3>{locale === 'en' ? 'More questions?' : 'Noch Fragen?'}</h3>
    <p style="color:var(--text-muted);margin:1rem 0 1.5rem">
      {locale === 'en' ? 'Free, no-obligation advisory' : 'Lassen Sie sich kostenlos und unverbindlich beraten'}
    </p>
    <a href={sections.kontakt} class="btn btn-primary">{t.cta}</a>
  </div>
</section>
