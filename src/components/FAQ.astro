---
import { faqs as coreFaqs } from '../data/site';
import { keywordFaqs } from '../data/keyword-faqs';
import { sections } from '../data/links';

// Core FAQs first, then keyword-driven long-tail (from Excel) — deduplicated
const seen = new Set<string>();
const allFaqs = [...coreFaqs, ...keywordFaqs].filter((faq) => {
  const key = faq.q.toLowerCase().trim();
  if (seen.has(key)) return false;
  seen.add(key);
  return true;
});
---

<section id="faq" class="section">
  <div class="container center">
    <p class="section-label" style="justify-content:center">❓ FAQ</p>
    <h2 class="section-title">Häufige Fragen zu Offplan-Investment in Ägypten</h2>
    <p class="section-desc">
      Antworten zu Renditepotenzial, zinsfreien Bauträger-Raten, Sicherheit, West Wind und mehr —
      basierend auf den häufigsten Suchanfragen unserer Investoren.
    </p>
  </div>

  <div class="container faq-list">
    {allFaqs.map((faq, i) => (
      <div class={`faq-item ${i === 0 ? 'open' : ''}`}>
        <button type="button" class="faq-question">{faq.q}</button>
        <div class="faq-answer">
          <p>{faq.a}</p>
        </div>
      </div>
    ))}
  </div>

  <div class="container comparison-cta" style="margin-top:2.5rem">
    <h3>Noch Fragen?</h3>
    <p style="color:var(--text-muted);margin:1rem 0 1.5rem">Lassen Sie sich kostenlos und unverbindlich beraten</p>
    <a href={sections.kontakt} class="btn btn-primary">Jetzt Beratungstermin buchen</a>
  </div>
</section>
