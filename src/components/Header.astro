---
import BrandLogo from './BrandLogo.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';
import { getLocale, type Locale } from '../i18n/index';
import { getUi } from '../i18n/strings';

interface Props {
  locale?: Locale;
}

const locale = Astro.props.locale ?? getLocale(Astro.url.pathname);
const { nav, cta, menuOpen } = getUi(locale);
const homeHref = locale === 'en' ? '/en/' : '/';
const contactHref = locale === 'en' ? '/en/#contact' : '/#kontakt';
---

<header class="header" role="banner">
  <div class="container header-inner">
    <a href={homeHref} class="logo" data-scroll-top>
      <BrandLogo />
    </a>

    <nav class="nav-desktop" aria-label={locale === 'en' ? 'Main navigation' : 'Hauptnavigation'}>
      {nav.map((link) => (
        <a href={link.href}>{link.label}</a>
      ))}
    </nav>

    <div class="header-actions">
      <LanguageSwitcher locale={locale} />
      <a href={contactHref} class="btn btn-primary nav-cta">{cta}</a>
    </div>

    <button class="menu-toggle" type="button" aria-label={menuOpen} aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</header>

<nav class="mobile-nav" aria-label={locale === 'en' ? 'Mobile navigation' : 'Mobile Navigation'}>
  <LanguageSwitcher locale={locale} />
  {nav.map((link) => (
    <a href={link.href}>{link.label}</a>
  ))}
  <a href={contactHref} class="btn btn-primary" style="margin-top: 1rem; text-align: center;">{cta}</a>
</nav>
