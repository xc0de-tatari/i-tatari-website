---
import { navLinks } from '../data/site';
import { images } from '../data/images';
import { sections } from '../data/links';
---

<header class="header" role="banner">
  <div class="container header-inner">
    <a href="/" class="logo" data-scroll-top>
      <img src={images.logo} alt="Tatari Investments" class="logo-img" width="140" height="48" />
    </a>

    <nav class="nav-desktop" aria-label="Hauptnavigation">
      {navLinks.map((link) => (
        <a href={link.href}>{link.label}</a>
      ))}
    </nav>

    <a href={sections.kontakt} class="btn btn-primary nav-cta">Kostenlose Beratung</a>

    <button class="menu-toggle" type="button" aria-label="Menü öffnen" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</header>

<nav class="mobile-nav" aria-label="Mobile Navigation">
  {navLinks.map((link) => (
    <a href={link.href}>{link.label}</a>
  ))}
  <a href={sections.kontakt} class="btn btn-primary" style="margin-top: 1rem; text-align: center;">Kostenlose Beratung</a>
</nav>
