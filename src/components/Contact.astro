---
import type { Locale } from '../i18n';
import SocialLinks from './SocialLinks.astro';
import { getPageSections, getUi } from '../i18n/content';
import { links } from '../data/links';
import { trackingConfig } from '../config/tracking.config';

interface Props {
  locale?: Locale;
}

const locale = Astro.props.locale ?? 'de';
const c = getUi(locale).contact;
const sections = getPageSections(locale);
---

<section id={c.id} class="section section-alt">
  <div class="container center">
    <p class="section-label" style="justify-content:center">{c.label}</p>
    <h2 class="section-title">
      {c.title} <span class="text-gold">{c.titleGold}</span>
    </h2>
    <p class="section-desc">{c.desc}</p>
  </div>

  <div class="container contact-grid">
    <div class="contact-info-grid">
      <div class="contact-card">
        <h3>{c.egypt}</h3>
        <a href={`tel:${links.phone}`}>{links.phoneDisplay}</a>
        <p>{c.phoneSub}</p>
      </div>
      <div class="contact-card">
        <h3>{c.email}</h3>
        <a href={`mailto:${links.email}`}>{links.email}</a>
        <p>{c.emailSub}</p>
      </div>
      <div class="contact-card">
        <h3>{c.frankfurt}</h3>
        <p>OpernTurm, Bockenheimer Landstraße 2-4, 60306 Frankfurt am Main</p>
      </div>
      <div class="contact-card">
        <h3>{c.cairo}</h3>
        <p>Sheikh Zayed City, Arkan Plaza, Building 4, Giza</p>
        <p style="margin-top:0.5rem;color:var(--gold)">{c.cairoSub}</p>
      </div>
      <div class="contact-card contact-card-social">
        <h3>{c.social}</h3>
        <SocialLinks variant="contact" showLabels />
        <p>{c.socialSub}</p>
      </div>
    </div>

    <form class="contact-form" id="contact-form" novalidate>
      <h3>{c.formTitle}</h3>
      <p>{c.formDesc}</p>
      <p id="form-status" class="form-status" role="status" aria-live="polite" hidden></p>
      <div class="form-group">
        <label for="name">{locale === 'en' ? 'Your name *' : 'Ihr Name *'}</label>
        <input id="name" name="name" type="text" placeholder={locale === 'en' ? 'John Smith' : 'Max Mustermann'} required autocomplete="name" />
      </div>
      <div class="form-group">
        <label for="email">{locale === 'en' ? 'Email *' : 'E-Mail-Adresse *'}</label>
        <input id="email" name="email" type="email" placeholder={locale === 'en' ? 'john@example.com' : 'max@beispiel.de'} required autocomplete="email" />
      </div>
      <div class="form-group">
        <label for="phone">{locale === 'en' ? 'Phone' : 'Telefonnummer'}</label>
        <input id="phone" name="phone" type="tel" placeholder="+49 123 456789" autocomplete="tel" />
      </div>
      <div class="form-group">
        <label for="message">{locale === 'en' ? 'Message *' : 'Ihre Nachricht *'}</label>
        <textarea id="message" name="message" placeholder={locale === 'en' ? 'I am interested in investing in...' : 'Ich interessiere mich für eine Investition in...'} required></textarea>
      </div>
      <button type="submit" class="btn btn-primary" id="form-submit">
        {locale === 'en' ? 'Send message' : 'Nachricht senden'}
      </button>
      <p class="form-note">{locale === 'en' ? '* Required fields.' : '* Pflichtfelder.'}</p>
      {trackingConfig.calendlyUrl && (
        <p class="form-note" style="margin-top:1rem">
          {locale === 'en' ? 'Or book a call:' : 'Oder Termin buchen:'}{' '}
          <a href={trackingConfig.calendlyUrl} target="_blank" rel="noopener noreferrer">Calendly</a>
        </p>
      )}
    </form>
  </div>

  <div class="container" style="margin-top:2rem;padding:1.5rem;background:var(--bg-card);border-radius:var(--radius-lg);border:1px solid var(--border)">
    <p style="color:var(--text-muted);font-size:0.9rem;text-align:center">{c.trip}</p>
  </div>

  <div class="container contact-bottom">
    <h3>{c.bottomTitle}</h3>
    <p style="color:var(--text-muted);margin:1rem 0">{c.bottomDesc}</p>
    <div class="contact-bottom-actions">
      <a href={`tel:${links.phone}`} class="btn btn-primary">{c.call}</a>
      <a href={`mailto:${links.email}`} class="btn btn-outline">{c.emailBtn}</a>
      <a href={links.whatsapp} class="btn btn-outline" target="_blank" rel="noopener noreferrer">WhatsApp</a>
    </div>
  </div>
</section>
