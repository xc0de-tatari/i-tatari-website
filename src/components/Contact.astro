---
import { links, sections } from '../data/links';
import { trackingConfig } from '../config/tracking.config';
---

<section id="kontakt" class="section section-alt">
  <div class="container center">
    <p class="section-label" style="justify-content:center">Kostenlose Beratung</p>
    <h2 class="section-title">
      Bereit für Ihre erste <span class="text-gold">Investition?</span>
    </h2>
    <p class="section-desc">
      Vereinbaren Sie jetzt ein kostenloses Beratungsgespräch mit unseren Experten.
    </p>
  </div>

  <div class="container contact-grid">
    <div class="contact-info-grid">
      <div class="contact-card">
        <h3>Ägypten</h3>
        <a href={`tel:${links.phone}`}>{links.phoneDisplay}</a>
        <p>WhatsApp & Anrufe</p>
      </div>
      <div class="contact-card">
        <h3>Per E-Mail</h3>
        <a href={`mailto:${links.email}`}>{links.email}</a>
        <p>Antwort innerhalb von 24 Stunden</p>
      </div>
      <div class="contact-card">
        <h3>Büro Frankfurt</h3>
        <p>OpernTurm, Bockenheimer Landstraße 2-4, 60306 Frankfurt am Main</p>
      </div>
      <div class="contact-card">
        <h3>Büro Kairo</h3>
        <p>Sheikh Zayed City, Arkan Plaza, Building 4, Giza</p>
        <p style="margin-top:0.5rem;color:var(--gold)">Vor-Ort-Besichtigungen möglich</p>
      </div>
    </div>

    <form class="contact-form" id="contact-form" novalidate>
      <h3>Kontaktieren Sie uns</h3>
      <p>Füllen Sie das Formular aus und wir melden uns innerhalb von 24 Stunden.</p>
      <p id="form-status" class="form-status" role="status" aria-live="polite" hidden></p>
      <div class="form-group">
        <label for="name">Ihr Name *</label>
        <input id="name" name="name" type="text" placeholder="Max Mustermann" required autocomplete="name" />
      </div>
      <div class="form-group">
        <label for="email">E-Mail-Adresse *</label>
        <input id="email" name="email" type="email" placeholder="max@beispiel.de" required autocomplete="email" />
      </div>
      <div class="form-group">
        <label for="phone">Telefonnummer</label>
        <input id="phone" name="phone" type="tel" placeholder="+49 123 456789" autocomplete="tel" />
      </div>
      <div class="form-group">
        <label for="message">Ihre Nachricht *</label>
        <textarea id="message" name="message" placeholder="Ich interessiere mich für eine Investition in..." required></textarea>
      </div>
      <button type="submit" class="btn btn-primary" id="form-submit">Nachricht senden</button>
      <p class="form-note">* Pflichtfelder. Ihre Daten werden vertraulich behandelt.</p>
      {trackingConfig.calendlyUrl && (
        <p class="form-note" style="margin-top:1rem">
          Oder Termin buchen:{' '}
          <a href={trackingConfig.calendlyUrl} target="_blank" rel="noopener noreferrer">
            Calendly / Beratungstermin
          </a>
        </p>
      )}
    </form>
  </div>

  <div class="container" style="margin-top:2rem;padding:1.5rem;background:var(--bg-card);border-radius:var(--radius-lg);border:1px solid var(--border)">
    <p style="color:var(--text-muted);font-size:0.9rem;text-align:center">
      Wir organisieren Besichtigungsreisen nach Dubai oder Ägypten inklusive Projektbesichtigung und Treffen mit den Entwicklern.
    </p>
  </div>

  <div class="container contact-bottom">
    <h3>Starten Sie noch heute Ihre Investitionsreise</h3>
    <p style="color:var(--text-muted);margin:1rem 0">
      Hunderte Deutsche haben bereits den Schritt gewagt. Werden Sie Teil der erfolgreichen Tatari-Familie.
    </p>
    <div class="contact-bottom-actions">
      <a href={`tel:${links.phone}`} class="btn btn-primary">Jetzt anrufen</a>
      <a href={`mailto:${links.email}`} class="btn btn-outline">E-Mail schreiben</a>
      <a href={links.whatsapp} class="btn btn-outline" target="_blank" rel="noopener noreferrer">WhatsApp</a>
    </div>
  </div>
</section>
