---
import type { Locale } from '../i18n';
import { getUi } from '../i18n/content';
import { clusters } from '../data/clusters';
import { getClusterIntro, getClusterHref } from '../data/cluster-intros';

interface Props {
  locale?: Locale;
}

const locale = Astro.props.locale ?? 'de';
const t = getUi(locale).seoTopics;
const pillarCards = getUi(locale).pillars.cards;

function clusterTitle(name: string) {
  return name.replace(/^\d+\s*/, '').trim();
}
---

<section class="section section-alt" aria-labelledby="seo-topics-title">
  <div class="container">
    <p class="section-label">{t.label}</p>
    <h2 id="seo-topics-title" class="section-title">{t.title}</h2>
    <p class="section-desc">{t.desc}</p>

    <div class="topics-grid">
      {locale === 'en'
        ? pillarCards.map((card) => (
            <article class="topic-card">
              <h3>{card.title}</h3>
              <p class="topic-sub">{card.desc}</p>
              <a href={card.href} class="topic-link">
                {card.link}
              </a>
            </article>
          ))
        : clusters.map((cluster) => {
            const intro = getClusterIntro(cluster.slug);
            return (
              <article class="topic-card">
                <h3>{intro.headline}</h3>
                <p class="topic-sub">{intro.subheadline}</p>
                <p class="topic-intro">{intro.intro}</p>
                <ul class="topic-highlights">
                  {intro.highlights.slice(0, 3).map((h) => (
                    <li>{h}</li>
                  ))}
                </ul>
                <a href={getClusterHref(cluster.slug)} class="topic-link">
                  {cluster.slug.includes('west-wind')
                    ? 'West Wind ansehen'
                    : `${clusterTitle(cluster.name)} — mehr erfahren`}
                  <span aria-hidden="true"> →</span>
                </a>
              </article>
            );
          })}
    </div>
  </div>
</section>

<style>
  .topics-grid {
    display: grid;
    gap: 1.25rem;
    margin-top: 2.5rem;
  }

  @media (min-width: 640px) {
    .topics-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .topics-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .topic-card {
    padding: 1.5rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    display: flex;
    flex-direction: column;
    min-height: 100%;
    transition: border-color 0.2s;
  }

  .topic-card:hover {
    border-color: var(--border-gold);
  }

  .topic-card h3 {
    font-size: 1.05rem;
    color: var(--text);
    margin-bottom: 0.35rem;
    line-height: 1.35;
    word-break: break-word;
  }

  .topic-sub {
    font-size: 0.8rem;
    color: var(--gold);
    margin-bottom: 0.65rem;
    line-height: 1.4;
  }

  .topic-intro {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.55;
    margin-bottom: 0.85rem;
    flex: 1;
  }

  .topic-highlights {
    margin-bottom: 1rem;
  }

  .topic-highlights li {
    font-size: 0.8rem;
    color: var(--text-dim);
    padding: 0.25rem 0 0.25rem 1rem;
    position: relative;
    line-height: 1.45;
  }

  .topic-highlights li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--gold);
    font-size: 0.7rem;
  }

  .topic-link {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--gold);
    margin-top: auto;
  }

  .topic-link:hover {
    text-decoration: underline;
  }
</style>
