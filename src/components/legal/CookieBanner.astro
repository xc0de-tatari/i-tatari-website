---
import { legalPaths } from '../../data/links';
---

<div
  id="cookie-banner-root"
  class="cookie-consent"
  role="dialog"
  aria-modal="true"
  aria-labelledby="cookie-banner-title"
  aria-hidden="true"
  hidden
>
  <div class="cookie-consent__glow" aria-hidden="true"></div>

  <div class="cookie-consent__dock">
    <article class="cookie-consent__card">
      <div class="cookie-consent__border" aria-hidden="true"></div>

      <div class="cookie-consent__view cookie-consent__view--main" data-cookie-view="main">
        <div class="cookie-consent__hero">
          <div class="cookie-consent__icon-wrap" aria-hidden="true">
            <span class="cookie-consent__icon-ring"></span>
            <span class="cookie-consent__icon">🍪</span>
          </div>
          <div class="cookie-consent__copy">
            <p class="cookie-consent__eyebrow">Privatsphäre</p>
            <h2 id="cookie-banner-title" class="cookie-consent__title">Cookies &amp; Datenschutz</h2>
            <p class="cookie-consent__text">
              Wir nutzen nur notwendige Speicherung — bis Sie zustimmen, keine Analyse- oder Marketing-Tracker.{' '}
              <a href={legalPaths.datenschutz}>Mehr erfahren</a>
            </p>
          </div>
        </div>

        <div class="cookie-consent__actions">
          <button type="button" class="cookie-btn cookie-btn--ghost" id="cookie-reject">
            Nur notwendige
          </button>
          <button
            type="button"
            class="cookie-btn cookie-btn--ghost"
            id="cookie-settings-open"
            aria-expanded="false"
            aria-controls="cookie-settings-panel"
          >
            <span class="cookie-btn__icon" aria-hidden="true">⚙</span>
            Einstellungen
          </button>
          <button type="button" class="cookie-btn cookie-btn--primary" id="cookie-accept-all">
            <span class="cookie-btn__shine" aria-hidden="true"></span>
            Alle akzeptieren
          </button>
        </div>
      </div>

      <div
        class="cookie-consent__view cookie-consent__view--settings"
        id="cookie-settings-panel"
        data-cookie-view="settings"
        aria-hidden="true"
      >
        <div class="cookie-consent__settings-head">
          <button type="button" class="cookie-consent__back" id="cookie-settings-back" aria-label="Zurück">
            ←
          </button>
          <div>
            <h3 class="cookie-consent__settings-title">Cookie-Einstellungen</h3>
            <p class="cookie-consent__settings-sub">Wählen Sie, welche Kategorien aktiv sein dürfen.</p>
          </div>
        </div>

        <ul class="cookie-consent__categories">
          <li class="cookie-category cookie-category--locked">
            <span class="cookie-category__icon" aria-hidden="true">🛡️</span>
            <div class="cookie-category__body">
              <strong>Notwendig</strong>
              <p>Speichert Ihre Auswahl — immer aktiv.</p>
            </div>
            <label class="cookie-switch" title="Immer aktiv">
              <input type="checkbox" checked disabled />
              <span class="cookie-switch__track"><span class="cookie-switch__thumb"></span></span>
            </label>
          </li>
          <li class="cookie-category">
            <span class="cookie-category__icon" aria-hidden="true">📊</span>
            <div class="cookie-category__body">
              <strong>Statistik</strong>
              <p>Google Analytics, Tag Manager — Nutzung verstehen.</p>
            </div>
            <label class="cookie-switch">
              <input type="checkbox" id="cookie-analytics" />
              <span class="cookie-switch__track"><span class="cookie-switch__thumb"></span></span>
            </label>
          </li>
          <li class="cookie-category">
            <span class="cookie-category__icon" aria-hidden="true">✨</span>
            <div class="cookie-category__body">
              <strong>Marketing</strong>
              <p>Meta, TikTok, LinkedIn, Google Ads — Conversion-Messung.</p>
            </div>
            <label class="cookie-switch">
              <input type="checkbox" id="cookie-marketing" />
              <span class="cookie-switch__track"><span class="cookie-switch__thumb"></span></span>
            </label>
          </li>
        </ul>

        <div class="cookie-consent__actions cookie-consent__actions--settings">
          <button type="button" class="cookie-btn cookie-btn--ghost" id="cookie-reject-settings">
            Nur notwendige
          </button>
          <button type="button" class="cookie-btn cookie-btn--primary" id="cookie-save-settings">
            <span class="cookie-btn__shine" aria-hidden="true"></span>
            Auswahl speichern
          </button>
        </div>
      </div>
    </article>
  </div>
</div>
