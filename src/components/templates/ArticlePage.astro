---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FloatingActions from '../../components/FloatingActions.astro';
import Breadcrumbs from '../../components/seo/Breadcrumbs.astro';
import JsonLd from '../../components/seo/JsonLd.astro';
import Disclaimer from '../../components/conversion/Disclaimer.astro';
import LeadForm from '../../components/conversion/LeadForm.astro';
import BlogCard from '../../components/conversion/BlogCard.astro';
import CTAButton from '../../components/conversion/CTAButton.astro';
import type { articles } from '../../data/articles';
import { articles as allArticles } from '../../data/articles';
import {
  canonicalUrl,
  buildArticleSchema,
  buildBreadcrumbSchema,
  buildFaqSchema,
  mergeSchemas,
} from '../../lib/seo';
import { sections } from '../../data/links';

type Article = (typeof articles)[number];

interface Props {
  article: Article;
}

const { article } = Astro.props;
const path = `/wissen/${article.slug}`;
const related = allArticles.filter((a) => a.slug !== article.slug).slice(0, 3);

const schemas = mergeSchemas(
  buildBreadcrumbSchema([
    { name: 'Start', url: '/' },
    { name: 'Wissen', url: '/wissen' },
    { name: article.title.slice(0, 50), url: path },
  ]),
  buildArticleSchema({ headline: article.title, description: article.seo.description, url: path }),
  buildFaqSchema(article.faqs)
);
---

<Layout
  title={article.seo.title}
  description={article.seo.description}
  canonical={canonicalUrl(path)}
  ogType="article"
  lang={article.lang === 'en' ? 'en' : 'de'}
>
  <Fragment slot="head"><JsonLd data={schemas} /></Fragment>
  <Header locale={article.lang === 'en' ? 'en' : 'de'} />
  <main id="main-content">
    <article class="section">
      <div class="container article-wrap">
        <Breadcrumbs
          items={
            article.lang === 'en'
              ? [
                  { name: 'Home', url: '/en/' },
                  { name: 'Insights', url: '/en/insights' },
                  { name: article.category, url: path },
                ]
              : [
                  { name: 'Start', url: '/' },
                  { name: 'Wissen', url: '/wissen' },
                  { name: article.category, url: path },
                ]
          }
        />
        <p class="section-label">{article.category}</p>
        <h1>{article.title}</h1>
        <p class="article-intro">{article.intro}</p>
        {article.sections.map((s) => (
          <section class="article-section">
            <h2>{s.h2}</h2>
            <p>{s.body}</p>
          </section>
        ))}
        {article.faqs.length > 0 && (
          <section class="article-faq">
            <h2>FAQ</h2>
            {article.faqs.map((f) => (
              <details>
                <summary>{f.q}</summary>
                <p>{f.a}</p>
              </details>
            ))}
          </section>
        )}
        <div class="article-cta-box">
          <h3>Beratung anfragen</h3>
          <p>Kostenlose Erstberatung — vorbehaltlich Verfügbarkeit.</p>
          <CTAButton href={sections.kontakt} label="Jetzt Beratung buchen" />
        </div>
        <Disclaimer compact />
      </div>
    </article>
    <section class="section section-alt">
      <div class="container">
        <h2 class="section-title">Weitere Artikel</h2>
        <div class="blog-grid">
          {related.map((a) => (
            <BlogCard article={a} />
          ))}
        </div>
      </div>
    </section>
    <section class="section">
      <div class="container">
        <LeadForm title="Fragen zu diesem Thema?" source={`article-${article.slug}`} compact />
      </div>
    </section>
  </main>
  <Footer locale={article.lang === 'en' ? 'en' : 'de'} />
  <FloatingActions />
</Layout>

<style>
  .article-wrap { max-width: 760px; }
  .article-intro { font-size: 1.1rem; color: var(--text-muted); margin: 1rem 0 2rem; }
  .article-section { margin-bottom: 2rem; }
  .article-section h2 { font-size: 1.25rem; margin-bottom: 0.75rem; color: var(--gold); }
  .article-faq details { margin-bottom: 0.75rem; border: 1px solid var(--border); border-radius: var(--radius); padding: 1rem; }
  .article-cta-box {
    margin: 2rem 0;
    padding: 1.5rem;
    background: var(--bg-card);
    border: 1px solid var(--border-gold);
    border-radius: var(--radius-lg);
    text-align: center;
  }
  .blog-grid { display: grid; gap: 1rem; margin-top: 1.5rem; }
  @media (min-width: 768px) { .blog-grid { grid-template-columns: repeat(3, 1fr); } }
</style>
