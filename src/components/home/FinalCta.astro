---
import type { Locale } from '../../i18n';
import { getPageSections, getUi } from '../../i18n/content';
import { links } from '../../data/links';

interface Props {
  locale?: Locale;
}

const locale = Astro.props.locale ?? 'de';
const t = getUi(locale).finalCta;
const sections = getPageSections(locale);
---

<section class="section final-cta">
  <div class="container center">
    <h2 class="section-title">{t.title}</h2>
    <p class="section-desc" style="max-width:560px;margin-inline:auto">{t.desc}</p>
    <div class="hero-actions" style="justify-content:center;margin-top:1.5rem">
      <a href={sections.kontakt} class="btn btn-primary btn-lg">
        {locale === 'en' ? 'Free consultation' : 'Kostenlose Investment-Beratung sichern'}
      </a>
      <a href={links.whatsapp} class="btn btn-outline" target="_blank" rel="noopener noreferrer">
        {locale === 'en' ? 'WhatsApp advisory' : 'WhatsApp-Beratung starten'}
      </a>
    </div>
  </div>
</section>

<style>
  .final-cta {
    background: linear-gradient(180deg, transparent, rgba(201, 162, 39, 0.06));
    border-top: 1px solid var(--border);
  }

  .btn-lg {
    padding: 1rem 2rem;
    font-size: 1.05rem;
  }
</style>
