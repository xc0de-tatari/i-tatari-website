---
import type { Locale } from '../../i18n';
import { getUi } from '../../i18n/content';
import { pillarPages, productPages } from '../../data/navigation';

interface Props {
  locale?: Locale;
}

const locale = Astro.props.locale ?? 'de';
const t = getUi(locale).pillars;

const morePillarLinks =
  locale === 'en'
    ? [
        { href: '/en/buy-property-egypt', label: 'Buy in Egypt' },
        { href: '/en/offplan-property-egypt', label: 'Offplan Egypt' },
        { href: '/en/real-estate-dubai', label: 'Dubai real estate' },
        { href: '/en/projects/west-wind', label: 'West Wind' },
        { href: '/en/insights', label: 'Insights' },
      ]
    : [...pillarPages, ...productPages];
---

<section class="section" id="investment-themen">
  <div class="container">
    <p class="section-label">{t.label}</p>
    <h2 class="section-title">{t.title}</h2>
    <p class="section-desc">{t.desc}</p>

    <div class="pillars-grid">
      {t.cards.map((card) => (
        <article class="pillar-card">
          <h3>{card.title}</h3>
          <p>{card.desc}</p>
          <a href={card.href}>{card.link}</a>
        </article>
      ))}
    </div>

    <nav class="pillars-more" aria-label={t.moreLabel}>
      {morePillarLinks.map((p) => (
        <a href={p.href}>{p.label}</a>
      ))}
    </nav>
  </div>
</section>

<style>
  .pillars-grid {
    display: grid;
    gap: 1rem;
    margin-top: 2rem;
  }

  @media (min-width: 640px) {
    .pillars-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .pillars-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .pillar-card {
    padding: 1.5rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
  }

  .pillar-card h3 {
    font-size: 1rem;
    color: var(--gold);
    margin-bottom: 0.5rem;
  }

  .pillar-card p {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
  }

  .pillar-card a {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--gold);
  }

  .pillars-more {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }

  .pillars-more a {
    font-size: 0.75rem;
    padding: 0.35rem 0.65rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    color: var(--text-muted);
  }

  .pillars-more a:hover {
    border-color: var(--border-gold);
    color: var(--gold);
  }
</style>
