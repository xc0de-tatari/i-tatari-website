---
import type { Locale } from '../../i18n';
import { getPageSections, getUi } from '../../i18n/content';
import { westWind } from '../../data/westwind';
import { westWindEn } from '../../data/westwind-en';
import { cityImages } from '../../data/images';
import { imageAlt } from '../../lib/seo';
import { links } from '../../data/links';

interface Props {
  locale?: Locale;
}

const locale = Astro.props.locale ?? 'de';
const t = getUi(locale).westWind;
const ww = locale === 'en' ? westWindEn : westWind;
const sections = getPageSections(locale);
const projectHref = locale === 'en' ? '/en/projects/west-wind' : '/projekte/west-wind';
---

<section class="section section-alt" id="west-wind-featured">
  <div class="container ww-featured">
    <div class="ww-featured-media">
      <img
        src={cityImages['Sheikh Zayed']}
        alt={imageAlt('West Wind mixed-use project', 'Clinics offices retail', 'Sheikh Zayed Egypt')}
        width="640"
        height="400"
        loading="lazy"
      />
    </div>
    <div>
      <p class="section-label">{t.label}</p>
      <h2 class="section-title">{t.title}</h2>
      <p class="section-desc">{ww.description}</p>
      <ul class="ww-featured-list">
        {ww.unitSpecs.map((u) => (
          <li>
            <strong>{u.type}</strong> {locale === 'en' ? 'from' : 'ab'} {u.sizeFrom} — {u.desc}
          </li>
        ))}
      </ul>
      <div class="hero-actions" style="justify-content:flex-start;margin-top:1.5rem">
        <a href={projectHref} class="btn btn-primary">
          {locale === 'en' ? ww.ctas.availability : 'West Wind Verfügbarkeit anfragen'}
        </a>
        <a href={sections.kontakt} class="btn btn-outline">
          {locale === 'en' ? ww.ctas.floorPlans : 'Grundrisse & Preise erhalten'}
        </a>
      </div>
      <p class="ww-note">{ww.disclaimers[0]}</p>
    </div>
  </div>
</section>

<style>
  .ww-featured {
    display: grid;
    gap: 2rem;
    align-items: center;
  }

  @media (min-width: 900px) {
    .ww-featured {
      grid-template-columns: 1fr 1fr;
    }
  }

  .ww-featured-media img {
    width: 100%;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
  }

  .ww-featured-list {
    margin-top: 1rem;
    display: grid;
    gap: 0.5rem;
  }

  .ww-featured-list li {
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  .ww-note {
    margin-top: 1rem;
    font-size: 0.75rem;
    color: var(--text-dim);
  }
</style>
