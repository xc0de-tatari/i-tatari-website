---
import { sections } from '../../data/links';
import { ctas } from '../../data/ctas';
---

<section class="section section-alt" id="deutsche-investoren">
  <div class="container">
    <p class="section-label">Für Investoren aus DACH</p>
    <h2 class="section-title">Deutschsprachige Beratung — von Deutschland aus starten</h2>
    <p class="section-desc">
      Sie müssen nicht allein navigieren: Tatari begleitet Erstgespräch, Vorprüfung, Euro-Kalkulation und optional
      Besichtigungsreise — vorbehaltlich Verfügbarkeit.
    </p>
    <div class="benefits-grid" style="margin-top:2rem">
      <article class="benefit-card">
        <div class="benefit-icon">🇩🇪</div>
        <h3>Beratung auf Deutsch</h3>
        <p>Telefon, WhatsApp, Video — ohne Sprachbarriere.</p>
      </article>
      <article class="benefit-card">
        <div class="benefit-icon">💶</div>
        <h3>Euro-Kalkulation</h3>
        <p>Alle Meilensteine in EUR nachvollziehbar planen.</p>
      </article>
      <article class="benefit-card">
        <div class="benefit-icon">✈️</div>
        <h3>Besichtigungsreise</h3>
        <p>Inspection Trip optional — <a href="/urlaub-und-investment-aegypten">Urlaub & Investment</a>.</p>
      </article>
      <article class="benefit-card">
        <div class="benefit-icon">📋</div>
        <h3>Vorprüfung</h3>
        <p>
          <a href="/immobilienfinanzierung-aegypten-deutsche">Ratenplan-Prüfung</a> statt Garantieversprechen.
        </p>
      </article>
    </div>
    <div class="center" style="margin-top:2rem">
      <a href={sections.kontakt} class="btn btn-primary">{ctas.consultation.label}</a>
    </div>
  </div>
</section>
