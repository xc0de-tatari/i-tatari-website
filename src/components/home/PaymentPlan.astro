---
import type { Locale } from '../../i18n';
import { getPageSections, getUi } from '../../i18n/content';

interface Props {
  locale?: Locale;
}

const locale = Astro.props.locale ?? 'de';
const t = getUi(locale).payment;
const sections = getPageSections(locale);
const instalmentHref = locale === 'en' ? '/en/installment-property-egypt' : '/immobilien-auf-raten-aegypten';
---

<section class="section" id={locale === 'en' ? 'payment-plan' : 'ratenzahlung'}>
  <div class="container">
    <p class="section-label">{t.label}</p>
    <h2 class="section-title">{t.title}</h2>
    <p class="section-desc">{t.desc}</p>
    <div class="benefits-grid" style="margin-top:2rem">
      {t.steps.map((step) => (
        <article class="benefit-card">
          <div class="benefit-icon">{step.n}</div>
          <h3>{step.title}</h3>
          <p>{step.desc}</p>
        </article>
      ))}
    </div>
    <p class="center" style="margin-top:1.5rem">
      <a href={instalmentHref} class="btn btn-outline">{t.link}</a>
      <a href={sections.kontakt} class="btn btn-primary" style="margin-left:0.75rem">{t.cta}</a>
    </p>
  </div>
</section>
