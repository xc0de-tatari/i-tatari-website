---
import type { Locale } from '../i18n';
import { getSiteContent, getPageSections, getUi } from '../i18n/content';
import { images } from '../data/images';
import OptimizedImage from './seo/OptimizedImage.astro';
import { defaultSizes } from '../lib/images';

interface Props {
  locale?: Locale;
}

const locale = Astro.props.locale ?? 'de';
const { heroStats } = getSiteContent(locale);
const t = getUi(locale).hero;
const sections = getPageSections(locale);
const dubaiHref = locale === 'en' ? '/en/real-estate-dubai' : '/immobilien-dubai';
const saudiHref = locale === 'en' ? '/en/real-estate-saudi-arabia' : '/immobilien-saudi-arabien';
---

<section class="hero" aria-labelledby="hero-heading">
  <div class="hero-bg" aria-hidden="true">
    <OptimizedImage
      src={images.heroBg}
      alt={t.imgAlt}
      width={1920}
      height={1080}
      priority
      sizes={defaultSizes('hero')}
      class="hero-bg-img"
    />
    <div class="hero-bg-overlay"></div>
  </div>
  <div class="container hero-content">
    <div class="hero-badge">
      <span class="badge badge-urgent">
        <span class="hero-dot"></span>
        {t.badge}
      </span>
    </div>

    <h1 id="hero-heading">
      {t.h1}<br />
      <span class="text-gradient">{t.h1Gradient}</span>
    </h1>

    <div class="hero-offer">
      <span style="font-size:1.25rem">⭐</span>
      <div>
        <strong>{t.offerTitle}</strong>
        <span>{t.offerSub}</span>
      </div>
    </div>

    <p class="hero-desc">
      <strong>{t.desc}</strong>
      {t.descStrong}
    </p>

    <div class="hero-actions">
      <a href={sections.kontakt} class="btn btn-primary">{t.ctaPrimary}</a>
      <a href={dubaiHref} class="btn btn-outline">Dubai</a>
      <a href={saudiHref} class="btn btn-outline">{locale === 'en' ? 'Saudi Arabia' : 'Saudi-Arabien'}</a>
    </div>

    <div class="hero-trust">
      {t.trust.map((line) => (
        <span>{line}</span>
      ))}
    </div>

    <div class="stats-grid hero-stats">
      {heroStats.map((stat) => (
        <div class="stat-card">
          <div class="stat-value">{stat.value}</div>
          <div class="stat-label">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>
