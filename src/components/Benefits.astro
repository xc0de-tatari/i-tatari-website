---
import type { Locale } from '../i18n';
import { getSiteContent, getUi } from '../i18n/content';

interface Props {
  locale?: Locale;
}

const locale = Astro.props.locale ?? 'de';
const { benefits } = getSiteContent(locale);
const t = getUi(locale).benefits;
const sectionId = locale === 'en' ? 'benefits' : 'vorteile';
---

<section id={sectionId} class="section">
  <div class="container">
    <p class="section-label">{t.label}</p>
    <h2 class="section-title">{t.title}</h2>
    <p class="section-desc">{t.desc}</p>

    <div class="benefits-grid">
      {benefits.map((b) => (
        <article class="benefit-card">
          <div class="benefit-icon">{b.icon}</div>
          <h3>{b.title}</h3>
          <p>{b.desc}</p>
        </article>
      ))}
    </div>

    <div class="highlight-box">
      <h3>{t.highlightTitle}</h3>
      <p>{t.highlightDesc}</p>
    </div>
  </div>
</section>
