---
import type { Locale } from '../i18n';
import { getSiteContent, getUi } from '../i18n/content';

interface Props { locale?: Locale }
const locale = Astro.props.locale ?? 'de';
const { securityItems } = getSiteContent(locale);
const t = getUi(locale).security;
---

<section class="section">
  <div class="container center">
    <p class="section-label" style="justify-content:center">{t.label}</p>
    <h2 class="section-title">{t.title}</h2>
    <p class="section-desc">{t.desc}</p>
    <p class="section-desc">{t.extra}</p>
  </div>

  <div class="container security-grid">
    {securityItems.map((item) => (
      <article class="security-card card">
        <h3>{item.title}</h3>
        <p>{item.desc}</p>
      </article>
    ))}
  </div>

  <div class="container cert-badges">
    <span class="cert-badge">🇩🇪 Beratung auf Deutsch</span>
    <span class="cert-badge">🏛️ Vertragslogik erklärt</span>
    <span class="cert-badge">🔒 DSGVO</span>
    <span class="cert-badge">🏗️ Bauträger-Direkt</span>
    <span class="cert-badge">✓ 500+ begleitete Investoren</span>
  </div>
</section>
